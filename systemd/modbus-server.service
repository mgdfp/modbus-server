[Unit]
Description=Modbus TCP server (Home Assistant <-> touchscreen bridge)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/src/modbus-server
ExecStart=%h/.local/bin/uv run python main.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
